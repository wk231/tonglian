# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  pod 'EasyPermissionX/Camera'

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Fix for iOS 18.5/Xcode 16.3+ std::allocator<const T> compatibility issue
      # This enables compatibility for std::allocator with const types (temporary workaround)
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << '_LIBCPP_ENABLE_REMOVED_ALLOCATOR_CONST=1'
    end
  end
  
  # Fix for Sentry C++ exception monitor missing <exception> header in iOS 18.5/Xcode 16.3+
  sentry_file = File.join(installer.sandbox.root, 'Sentry/Sources/SentryCrash/Recording/Monitors/SentryCrashMonitor_CPPException.cpp')
  if File.exist?(sentry_file)
    # Make file writable
    File.chmod(0644, sentry_file)
    sentry_content = File.read(sentry_file)
    unless sentry_content.include?('#include <exception>')
      # Add #include <exception> after the other includes and before typeinfo
      sentry_content.sub!(/(#include <typeinfo>)/, "#include <exception>\n\\1")
      File.write(sentry_file, sentry_content)
      puts "✅ Patched SentryCrashMonitor_CPPException.cpp to add <exception> header"
    end
  end
  
  # Fix for Sentry machine context missing ucontext64_t header in iOS 18.5/Xcode 16.3+
  sentry_machine_file = File.join(installer.sandbox.root, 'Sentry/Sources/SentryCrash/Recording/Tools/SentryCrashMachineContext.c')
  if File.exist?(sentry_machine_file)
    # Make file writable
    File.chmod(0644, sentry_machine_file)
    sentry_machine_content = File.read(sentry_machine_file)
    unless sentry_machine_content.include?('#include <sys/_types/_ucontext64.h>')
      # Add #include <sys/_types/_ucontext64.h> before the #ifdef __arm64__ block
      sentry_machine_content.sub!(/(#ifdef __arm64__)/, "#include <sys/_types/_ucontext64.h>\n\n\\1")
      File.write(sentry_machine_file, sentry_machine_content)
      puts "✅ Patched SentryCrashMachineContext.c to add <sys/_types/_ucontext64.h> header"
    end
  end
end
